# ============================================
# NewsFlow Bot Configuration
# ============================================
# Copy this file to .env and fill in your values
# Only DISCORD_TOKEN or TELEGRAM_TOKEN is required
#
# Keep comments on their OWN lines, never after a value: systemd's
# EnvironmentFile= takes everything after `=` literally, so an inline
# comment would become part of the value and crash config validation.
# (Docker's env_file and python-dotenv strip them — systemd doesn't.)

# === Platform Tokens (at least one required) ===
# Uncomment the line(s) you need and paste your real token. DO NOT leave
# the placeholder values uncommented — the bot will try to log in with
# them and crash on InvalidToken.
#DISCORD_TOKEN=
#TELEGRAM_TOKEN=

# === Database ===
# Default: SQLite (zero-config)
# DATABASE_URL=sqlite+aiosqlite:///./data/newsflow.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/newsflow

# === Translation (Optional) ===
TRANSLATION_ENABLED=false
# Options: deepl, openai, google
TRANSLATION_PROVIDER=deepl

# DeepL (https://www.deepl.com/pro-api)
# DEEPL_API_KEY=your_deepl_api_key

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-5.4-nano
# OPENAI_BASE_URL=  # For OpenAI-compatible APIs

# Google Cloud Translation
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# GOOGLE_PROJECT_ID=your_project_id

# === Scheduling ===
# How often to check feeds
FETCH_INTERVAL_MINUTES=60
# Max feeds fetched concurrently per round (bounds the fetcher's semaphore
# and open HTTP connections). Raise for large feed counts on a fast host.
# FEED_MAX_CONCURRENT=10
# How often the cleanup loop runs
CLEANUP_INTERVAL_HOURS=24
# Drop feed entries older than this
ENTRY_RETENTION_DAYS=7
# Don't dispatch entries whose published_at is older than this many days,
# even if they look "new" to the bot — guards against feeds re-serving
# their archive after cleanup. Entries without a published_at always
# pass through. Set to 0 to disable the filter.
MAX_ENTRY_PUBLISH_AGE_DAYS=14
# How long to keep SentEntry rows. SentEntry is the dedupe signal
# ("this channel already saw this feed_id+guid"); if it's deleted while
# the source feed still serves the same guid, the next fetch creates a
# fresh FeedEntry and dispatch will re-deliver. Must be >> entry retention.
# 90 days is generous; storage cost is small.
SENT_ENTRY_RETENTION_DAYS=90

# === Cache ===
# Options: memory, redis
CACHE_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0
# TTL for the memory/Redis translation cache (days)
# TRANSLATION_CACHE_TTL_DAYS=7

# === AI Digest (Optional, requires OPENAI_API_KEY) ===
# Generates periodic daily / weekly summaries of what the channel received.
# Enable it per-channel via Discord `/digest enable` or Telegram `/digest enable`.
# DIGEST_PROVIDER=openai
# DIGEST_MODEL=gpt-5.4-mini                   # Default; gpt-5.4-nano is cheaper
# DIGEST_MAX_INPUT_CHARS_PER_ARTICLE=300      # Budget per article in the prompt
# (article count per digest is set per-channel via /digest enable)
# DIGEST_CHECK_INTERVAL_MINUTES=5             # How often to check for due digests

# Prepend a visible header (and an `@here` mention on Discord) when
# delivering digests. Cuts through channel silence for daily/weekly
# briefings. Default off so existing deploys don't suddenly start
# pinging users. For Discord mentions to actually notify, the bot role
# needs "Mention Everyone" permission in the target channel — without
# it the token appears as literal text without a ping. Other platforms
# just get the visible header.
# DIGEST_MENTION_ON_DELIVERY=true

# Auto-pin each delivered digest (and unpin the previous one) so the
# channel's pin list always shows the latest digest at the top — one
# click on the 📌 jumps straight back to it. Requires "Manage Messages"
# on Discord or admin rights on Telegram. Pin failures degrade silently:
# the digest still delivers, the old pin stays, a warning is logged.
# Silent no-op on webhook destinations. Default off.
# DIGEST_AUTO_PIN=true

# === Custom AI prompt overrides (Optional) ===
# Built-in prompts are tuned for general-purpose news. Override these if you
# want a different tone / format. See GUIDE.md for placeholder reference.
#   Translation supports {source_desc} and {target_name}.
#   Digest supports {window} and {lang}.
# Invalid placeholders silently fall back to the built-in defaults.
# TRANSLATION_SYSTEM_PROMPT="You are a translator..."
# DIGEST_SYSTEM_PROMPT="You are a news editor..."

# === Webhook Adapter (Optional) ===
# Output-only HTTP push. Enabled iff the file below actually exists on disk
# — presence of the file is the opt-in. Drop samples/webhooks.example.yaml
# in as a starting point. See GUIDE.md §4 for the full schema.
# NOTE: under Docker, compose already points this at /app/config/webhooks.yaml
# (the host ./config dir) — just create config/webhooks.yaml. The path below is
# the bare-metal default.
# WEBHOOKS_CONFIG_PATH=./data/webhooks.yaml

# === REST API (Optional) ===
API_ENABLED=false
API_HOST=0.0.0.0
# NOTE (Docker): the container always listens on 8000 (compose pins it);
# this value applies to bare-metal runs. To publish a different HOST port
# under Docker: API_PORT=9000 docker compose -f docker/docker-compose.yml up -d
API_PORT=8000
# Shared secret for API write endpoints (feed mutations + inbound /api/ingest).
# Empty = all write endpoints are disabled (fail-closed); reads stay open.
# Required for inbound push. Send as `Authorization: Bearer <API_KEY>`.
# API_KEY=change-me-to-a-long-random-string

# === Non-RSS sources (Optional) ===
# Declarative JSON-API / IMAP-email / inbound-webhook sources, reconciled into
# the DB on startup (the counterpart to webhooks.yaml). Enabled iff the file
# below exists. See samples/sources.example.yaml and GUIDE.md §4B.
# Extras: make install-all  (or: pip install -e '.[source-json,source-email]')
# NOTE: under Docker, compose already points this at /app/config/sources.yaml
# (the host ./config dir) — just create config/sources.yaml. The path below is
# the bare-metal default.
# SOURCES_CONFIG_PATH=./data/sources.yaml

# === Logging ===
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Options: console, json
LOG_FORMAT=console

# === Quota Limits (0 = unlimited) ===
# MAX_FEEDS_PER_CHANNEL=0

# === Admin (Optional) ===
# ADMIN_USER_IDS=["123456789", "987654321"]
