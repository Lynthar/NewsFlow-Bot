# ============================================
# NewsFlow Bot Configuration
# ============================================
# Copy this file to .env and fill in your values
# Only DISCORD_TOKEN or TELEGRAM_TOKEN is required

# === Platform Tokens (at least one required) ===
# Uncomment the line(s) you need and paste your real token. DO NOT leave
# the placeholder values uncommented — the bot will try to log in with
# them and crash on InvalidToken.
#DISCORD_TOKEN=
#TELEGRAM_TOKEN=

# === Database ===
# Default: SQLite (zero-config)
# DATABASE_URL=sqlite+aiosqlite:///./data/newsflow.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/newsflow

# === Translation (Optional) ===
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=deepl  # Options: deepl, openai, google

# DeepL (https://www.deepl.com/pro-api)
# DEEPL_API_KEY=your_deepl_api_key

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-5.4-nano
# OPENAI_BASE_URL=  # For OpenAI-compatible APIs

# Google Cloud Translation
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# GOOGLE_PROJECT_ID=your_project_id

# === Scheduling ===
FETCH_INTERVAL_MINUTES=60      # How often to check feeds
CLEANUP_INTERVAL_HOURS=24      # How often the cleanup loop runs
ENTRY_RETENTION_DAYS=7         # Drop feed entries older than this

# === Cache ===
CACHE_BACKEND=memory  # Options: memory, redis
# REDIS_URL=redis://localhost:6379/0
# TRANSLATION_CACHE_TTL_DAYS=7   # TTL for memory/Redis translation cache

# === AI Digest (Optional, requires OPENAI_API_KEY) ===
# Generates periodic daily / weekly summaries of what the channel received.
# Enable it per-channel via Discord `/digest enable` or Telegram `/digest enable`.
# DIGEST_PROVIDER=openai
# DIGEST_MODEL=gpt-5.4-mini                   # Default; gpt-5.4-nano is cheaper
# DIGEST_MAX_ARTICLES=50                      # Cap articles per digest
# DIGEST_MAX_INPUT_CHARS_PER_ARTICLE=300      # Budget per article in the prompt
# DIGEST_CHECK_INTERVAL_MINUTES=5             # How often to check for due digests

# === Custom AI prompt overrides (Optional) ===
# Built-in prompts are tuned for general-purpose news. Override these if you
# want a different tone / format. See GUIDE.md for placeholder reference.
#   Translation supports {source_desc} and {target_name}.
#   Digest supports {window} and {lang}.
# Invalid placeholders silently fall back to the built-in defaults.
# TRANSLATION_SYSTEM_PROMPT="You are a translator..."
# DIGEST_SYSTEM_PROMPT="You are a news editor..."

# === Webhook Adapter (Optional) ===
# Output-only HTTP push. Enabled iff the file below actually exists on disk
# — presence of the file is the opt-in. Drop samples/webhooks.example.yaml
# in as a starting point. See GUIDE.md §4 for the full schema.
# WEBHOOKS_CONFIG_PATH=./data/webhooks.yaml

# === REST API (Optional) ===
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8000

# === Logging ===
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=console  # Options: console, json

# === Quota Limits (0 = unlimited) ===
# MAX_FEEDS_PER_CHANNEL=0
# MAX_ENTRIES_PER_FEED=0

# === Admin (Optional) ===
# ADMIN_USER_IDS=["123456789", "987654321"]
